{
  "parserPreset": {
    "parserOpts": {
      "headerPattern": "^([A-Z]+-\\d+):?\\s(.+)$",
      "headerCorrespondence": ["type", "subject"]
    }
  },
  "rules": {
    "type-empty": [2, "never"],
    "subject-empty": [2, "never"],
    "subject-case": [2, "never", ["start-case", "pascal-case", "upper-case"]],
    "header-max-length": [2, "always", 140],
    "body-max-line-length": [2, "always", 200]
  }
}
