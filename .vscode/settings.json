{
  "search.exclude": {
    "**/node_modules": true,
    "package-lock.json": true
  },
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "always",
    "source.organizeImports": "always"
  },
  "eslint.validate": ["javascript", "typescript"],
  "cSpell.words": ["hyperconverged", "kubevirt"],
  "yaml.validate": true,
  "files.associations": {
    "ci-scripts/hot-cluster/helm/**/templates/*.yaml": "helm"
  }
}
