  "engines": {
    "npm": ">=10.9.0",
    "node": ">=22.0.0"
  },
  "lint-staged": {
    "src/**/*.{js,ts,tsx,jsx,json}": [
      "npm run i18n"
    ],
    "*.{js,ts,tsx,jsx}": [
      "eslint --config eslintv10.config.js --no-warn-ignored --fix"
    ],
    "*.scss": [
      "stylelint --fix"
    ],
    "!(*.js|*.jsx|*.ts|*.tsx|*.scss)": [
      "prettier --write --ignore-unknown"
    ]
  },
  "name": "kubevirt-plugin",
  "overrides": {
    "@stolostron/multicluster-sdk": {
      "@openshift-console/dynamic-plugin-sdk": "4.23.0-prerelease.3",
      "react-i18next": "~16.5.8"
    },
    "delaunator": "4.0.1",
    "esbuild-loader": {
      "esbuild": "^0.28.1"
    }
  },
  "private": true,
  "scripts": {
    "build": "npm run clean && NODE_ENV=production NODE_OPTIONS=--max-old-space-size=8192 npm run ts-node -- node_modules/.bin/webpack",
    "check-types": "tsc",
    "check-types:playwright": "tsc --noEmit --project playwright/tsconfig.json",
    "clean": "rm -rf dist",
    "playwright-install": "playwright install chromium",
    "playwright-report": "playwright show-report ./playwright/test-results/html-report",
    "dev": "npm run clean && NODE_ENV=development NODE_OPTIONS=--max-old-space-size=8192 npm run ts-node -- node_modules/.bin/webpack serve --progress",
    "export-pos": "./i18n-scripts/export-pos.sh",
    "i18n": "i18next --silent && node ./i18n-scripts/set-english-defaults.js && ./i18n-scripts/replace-br.sh",
    "i18n:verbose": "i18next && node ./i18n-scripts/set-english-defaults.js && ./i18n-scripts/replace-br.sh",
    "i18n-dummy-locale": "node ./i18n-scripts/dummy-locale.js",
    "i18n-to-po": "node ./i18n-scripts/i18n-to-po.js",
    "lint": "eslint . --color && prettier . --ignore-unknown --check --ignore-path .prettierignorecode",
    "lint:fix": "eslint . --color --fix && prettier . --ignore-unknown --write --ignore-path .prettierignorecode",
    "lint-staged": "lint-staged",
    "memsource-download": "./i18n-scripts/memsource-download.sh",
    "memsource-upload": "./i18n-scripts/memsource-upload.sh",
    "oc-login-start-console": "./oc-login-start-console.sh",
    "po-to-i18n": "node ./i18n-scripts/po-to-i18n.js",
    "postinstall": "cp node_modules/@openshift-console/dynamic-plugin-sdk/docs/console-extensions.md .",
    "prepare": "husky",
    "start": "npm run ts-node -- node_modules/.bin/webpack serve",
    "start-console": "./start-console.sh",
    "start-console-with-monitoring": "./start-console.sh monitoring-plugin",
    "start-console-with-networking": "./start-console.sh networking-console-plugin",
    "start-console-with-lightspeed": "./start-console.sh lightspeed-console-plugin",
    "start-console-with-nmstate": "./start-console.sh nmstate-console-plugin",
    "test": "jest",
    "test-cov": "jest --coverage",
    "test-playwright": "playwright test --config=playwright.config.ts",
    "test-playwright-headless": "HEADLESS=true playwright test --config=playwright.config.ts",
    "test-playwright-ui": "playwright test --config=playwright.config.ts --ui",
    "ts-node": "ts-node -O '{\"module\":\"commonjs\"}'"
  },
  "version": "0.0.0"
}
